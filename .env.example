# ============================================
# AI 生活助手 — 环境变量配置模板
# 复制为 .env 后填入真实值
#   cp .env.example .env
# ============================================

# ─── 数据库 ──────────────────────────────────
DB_HOST=39.105.51.168
DB_PORT=3306
DB_NAME=life_assistant
DB_USERNAME=root
DB_PASSWORD=请替换为真实数据库密码

# ─── DeepSeek AI ─────────────────────────────
DEEPSEEK_API_KEY=请替换为真实API Key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── JWT ─────────────────────────────────────
# 至少32字符，生成方式: openssl rand -base64 32
JWT_SECRET=请替换为随机生成的至少32字符的密钥

# ─── 服务器 ──────────────────────────────────
SERVER_PORT=8082

# ─── 部署 ────────────────────────────────────
DEPLOY_HOST=39.105.51.168
DEPLOY_USER=root
DEPLOY_PATH=/app/life-assistant
